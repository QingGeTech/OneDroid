<resources>

    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/color_primary_1</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>
        <item name="fabStyle">@style/fabStyle</item>
    </style>


    <style name="ThemeOverlay.App.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.App.Button.TextButton.Dialog.FullWidth" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:maxWidth">@null</item>
    </style>

    <style name="ThemeOverlay.App.MaterialAlertDialog.FullWidthButtons" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="buttonBarPositiveButtonStyle">
            @style/Widget.App.Button.TextButton.Dialog.FullWidth
        </item>
        <item name="buttonBarNegativeButtonStyle">
            @style/Widget.App.Button.TextButton.Dialog.FullWidth
        </item>
        <item name="buttonBarNeutralButtonStyle">
            @style/Widget.App.Button.TextButton.Dialog.FullWidth
        </item>
    </style>

    <style name="fabStyle" parent="@style/Widget.Material3.ExtendedFloatingActionButton.Icon.Primary">
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>